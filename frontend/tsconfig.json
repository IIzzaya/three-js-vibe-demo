{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@experience/*": ["Experience/*"],
      "@utils/*": ["Experience/Utils/*"],
      "@world/*": ["Experience/World/*"],
      "@styles/*": ["styles/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
